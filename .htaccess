# Apache Routing Configuration for phpMyAdmin / PHP deployments
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Allow physical files (CSS, HTML, JS, images, client.js, api.php) to serve directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Redirect virtual API endpoints /api/* to api.php
  RewriteRule ^api/(.*)$ api.php [QSA,L]

  # Default fallback routes (Single Page Router) to index.html
  RewriteRule ^(.*)$ index.html [L]
</IfModule>
